{
  "compilerOptions": {
    "target": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"],
      "@@/*": ["./.dumi/tmp/*"],
      "@rc-component/tree": ["./src/index.ts"],
      "@rc-component/tree/es": ["./src"],
      "@rc-component/tree/es/*": ["./src/*"]
    },
    "strict": false,
    "module": "ESNext"
  },
  "include": [
    "global.d.ts",
    ".dumirc.ts",
    ".fatherrc.ts",
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./docs/**/*.tsx",
    "./tests/**/*.tsx"
  ],
  "exclude": ["docs-dist", "lib", "es"]
}
